# TODO: 请在这里填入本地辅助模式使用的 Excel 文件或文件夹绝对路径
EXCEL_INPUT_PATH=/Users/yourname/Documents/舆情监测主体
EXCEL_UPLOAD_DIR=/Users/yourname/project/data/uploads
EXCEL_TARGET_COLUMN_LETTER=B

# 搜索配置，可选: tavily / duckduckgo / bing / serpapi
SEARCH_PROVIDER=tavily
REQUEST_DELAY_SECONDS=1.5
REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRY_ATTEMPTS=3
REQUEST_RETRY_BACKOFF_SECONDS=3
REQUEST_RETRY_BACKOFF_MAX_SECONDS=20
MAX_RESULTS_PER_ENTITY=10
MAX_EXCEL_FILES=50

# TODO: 请在这里填入 Tavily Key
TAVILY_API_KEY=
TAVILY_TOPIC=news
TAVILY_SEARCH_DEPTH=advanced
TAVILY_TIME_RANGE=day
TAVILY_INCLUDE_RAW_CONTENT=markdown
TAVILY_CHUNKS_PER_SOURCE=3

# TODO: 如使用 Bing News Search，请在这里填入 Key
BING_SUBSCRIPTION_KEY=
BING_ENDPOINT=https://api.bing.microsoft.com/v7.0/news/search
BING_MARKET=zh-CN

# TODO: 如使用 SerpAPI，请在这里填入 Key
SERPAPI_API_KEY=
SERPAPI_ENDPOINT=https://serpapi.com/search.json
SERPAPI_GL=cn
SERPAPI_HL=zh-cn

# DuckDuckGo 区域
DDG_REGION=cn-zh

# TODO: 请在这里填入 OpenAI 或兼容模型服务配置
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o
LLM_MAX_ARTICLES_FOR_PROMPT=50
EMAIL_SUMMARY_CHAR_LIMIT=220

# TODO: 请在这里填入 SMTP 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=
SMTP_SENDER=sender@example.com
SMTP_USE_SSL=true

# TODO: 请在这里填入收件人邮箱，多人请用英文逗号分隔
EMAIL_RECIPIENTS=liuguangyuan@natrust.cn

# 定时触发时间
SCHEDULE_TIME=07:30
